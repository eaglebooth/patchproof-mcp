# PatchProof MCP — example environment configuration.
# Copy to .env and edit; .env is git-ignored.
#
# Most users should leave the defaults. The variables below are
# documented exhaustively but only the ones that meaningfully change
# runtime behavior are worth changing in practice.

# ---------------------------------------------------------------------------
# Transport selection
# ---------------------------------------------------------------------------
# PATCHPROOF_TRANSPORT: "stdio" (default, for MCP host processes) or "http"
PATCHPROOF_TRANSPORT=stdio

# PATCHPROOF_HTTP_HOST: bind address for the Streamable HTTP transport.
# Default "127.0.0.1" (local-only). Set PATCHPROOF_HTTP_PUBLIC=1 to opt
# into binding 0.0.0.0 inside the container.
PATCHPROOF_HTTP_HOST=127.0.0.1

# PATCHPROOF_HTTP_PORT: port for the Streamable HTTP transport.
PATCHPROOF_HTTP_PORT=8765

# PATCHPROOF_HTTP_PUBLIC: when set to 1, bind on 0.0.0.0. Off by default.
PATCHPROOF_HTTP_PUBLIC=0

# ---------------------------------------------------------------------------
# OSV adapter
# ---------------------------------------------------------------------------
# PATCHPROOF_OSV_MODE: "mock" (default, deterministic, no network) or
# "live" (queries api.osv.dev). CI should always use "mock".
PATCHPROOF_OSV_MODE=mock

# PATCHPROOF_OSV_TIMEOUT_MS: per-request timeout for live OSV.
PATCHPROOF_OSV_TIMEOUT_MS=5000

# PATCHPROOF_OSV_RETRIES: max retries for transient live OSV failures.
PATCHPROOF_OSV_RETRIES=2

# PATCHPROOF_OSV_CACHE_TTL_MS: in-memory TTL for OSV responses.
PATCHPROOF_OSV_CACHE_TTL_MS=3600000

# PATCHPROOF_OSV_RATE_PER_MIN: sliding-window rate limit for live OSV.
PATCHPROOF_OSV_RATE_PER_MIN=60

# ---------------------------------------------------------------------------
# Scanner / resource limits
# ---------------------------------------------------------------------------
PATCHPROOF_MAX_FILES=50000
PATCHPROOF_MAX_BYTES=524288000
PATCHPROOF_MAX_DEPTH=10
PATCHPROOF_SCAN_TIMEOUT_MS=60000
PATCHPROOF_VERIFY_TIMEOUT_MS=120000

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# MCP_QUIET: when set to 1, suppress all non-error logging on stderr.
MCP_QUIET=0

# ---------------------------------------------------------------------------
# Demo
# ---------------------------------------------------------------------------
# PATCHPROOF_DEMO_PORT: port for the bundled browser demo API.
PATCHPROOF_DEMO_PORT=8787
